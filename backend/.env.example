# EpiChat Backend Environment Variables
# -----------------------------------------------
# Copy this file to .env and fill in your keys.

# JWT Secret (required — used to sign auth tokens)
# Generate a random one: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-random-secret-key-here

# Option A: OpenAI API key (paid)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Option B: Google Gemini API key (FREE)
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Welcome Email via Gmail SMTP (optional)
# 1. Enable 2FA on your Gmail account
# 2. Generate an App Password: myaccount.google.com/apppasswords
# 3. Fill in below — leave blank to disable emails (login still works)
SMTP_EMAIL=your_gmail@gmail.com
SMTP_PASSWORD=your_gmail_app_password
# -----------------------------------------------

